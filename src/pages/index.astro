---
import { promises as fs } from 'fs';
import path from 'path';
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar';
import ResumeSection from '../components/ResumeSection';
import BackToTop from '../components/BackToTop';
import { parseResume } from '../lib/parseResume';
import { parseAchievements } from '../lib/parseCards';
import AchievementModal from '../components/AchievementModal';
import '../styles/print.css';

// 讀取 content/resume.md
const resumePath = path.join(process.cwd(), 'content', 'resume.md');
const raw = await fs.readFile(resumePath, 'utf-8');
const { meta, sections } = parseResume(raw);
const achievementSection = sections.find((section) =>
  section.heading.toLowerCase().includes('achievement')
);
const achievementCards = achievementSection ? parseAchievements(achievementSection.body) : [];
---

<Layout title={`${meta.name} — ${meta.title}`}>
  <div class="min-h-screen lg:flex bg-white">
    <Sidebar client:load meta={meta} />

    <main class="resume-main flex-1 lg:ml-96 px-8 py-12 lg:px-20 lg:py-16 max-w-5xl">
      <!-- 螢幕版不顯示（已在側邊欄），列印版才顯示的頁首 -->
      <header class="print-header">
        <div class="print-header-name">
          <h1>{meta.name}</h1>
          <div class="print-header-title">{meta.title}</div>
        </div>
        <ul class="print-header-contact">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span>{meta.email}</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
            <span>{meta.phone}</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            <span>{meta.github.replace(/^https?:\/\//, '')}</span>
          </li>
        </ul>
      </header>

      {sections.map((section) => <ResumeSection client:load section={section} />)}

      <footer class="mt-16 pt-8 border-t border-gray-200 text-sm text-gray-500 print:hidden">
        © {new Date().getFullYear()} {meta.name}.
      </footer>
    </main>
  </div>

  <BackToTop client:load />
  <AchievementModal client:load cards={achievementCards} />
</Layout>
