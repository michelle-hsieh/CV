---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="個人履歷 — Software Engineer" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700;900&family=Noto+Serif+TC:wght@400;600;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>
  <body class="bg-paper text-ink font-sans antialiased tracking-[0.01em] leading-relaxed">
    <slot />
  </body>
</html>
